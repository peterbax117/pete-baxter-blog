---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="About" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">About</div>
  </div>

  <div class="mb-10 text-justify">
    I'm Pete Baxter, a Cloud Solution Architect working with financial services
    customers. I spend most of my time on Azure architecture and the engineering
    that goes with it. This site is where I write up the work in more depth than
    fits in a post — the problems, the tradeoffs, and what actually shipped.
    <!-- TODO: replace this with your own bio. -->
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Cloud Solution Architect"
      subtitle="Microsoft"
    >
      <!-- TODO: describe your role and focus areas. -->
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>TODO: add certifications (with links)</li>
  </ul>

